{
  "name": "infrastructure",
  "version": "1.0.0",
  "description": "AWS CDK Infrastructure for migration project",
  "main": "bin/app.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy:environment": "cdk deploy EnvironmentStack --require-approval never",
    "deploy:client-infra": "cdk deploy ClientInfraStack --require-approval never",
    "deploy:ecs": "cdk deploy EcsStack --require-approval never",
    "deploy:all": "cdk deploy --all --require-approval never",
    "lint": "eslint . --ext .ts",
    "test": "jest"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "aws-cdk": "2.x",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "~5.4.0"
  },
  "dependencies": {
    "aws-cdk-lib": "2.x",
    "constructs": "^10.0.0",
    "source-map-support": "^0.5.21"
  }
}
